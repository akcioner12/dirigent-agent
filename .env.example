# Telegram Bot (BotFather) — для оркестратора и публикации в твой канал
BOT_TOKEN=

# Telegram User API (my.telegram.org) — нужен для мониторинга ЧУЖИХ каналов
# Бот не может читать чужие публичные каналы без подключения как админ,
# поэтому мониторинг конкурентов идёт через user-аккаунт (Telethon), не через бота.
TG_API_ID=
TG_API_HASH=

# Anthropic API — для rewriter-субагента
ANTHROPIC_API_KEY=

# Твой Telegram ID (для уведомлений/прав доступа к командам бота)
ADMIN_TELEGRAM_ID=213829809

# Канал назначения, куда публикуются одобренные посты
TARGET_CHANNEL=@Crypto_AI_Forex
